# Flask app
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
FLASK_APP_URL=http://127.0.0.1:5000

# Packet capture
CAPTURE_INTERFACE=enp0s3
CAPTURE_FILTER=
ROTATE_INTERVAL_SECONDS=30
ROTATE_MAX_SIZE_MB=50

# Dispatcher and processing
DISPATCHER_POLL_INTERVAL_SECONDS=5
MAX_PROCESSING_WORKERS=4
PROCESSING_TIMEOUT_SECONDS=300
QUEUE_MAXSIZE=10
FORCE_CPU=true

# Feature extraction thresholds
FLOW_TIMEOUT_NS=1200000000
MAX_FLOW_DURATION_NS=120000000000
ACTIVE_THRESHOLD_US=1000000

# Paths
MODEL_PATH=./detection_module/trained_models/final_drl1.pt
PROCESSED_FEATURES_DIR=./capapp/features_output
PREDICTION_OUTPUT_DIR=./data/predictions

# Model updater
MODEL_API_URL=http://192.168.0.208:8000/api/pipeline/model/download
MODEL_UPDATE_INTERVAL_HOURS=2
